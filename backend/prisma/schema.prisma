generator client {
  provider = "prisma-client"
  output   = "./src/infrastructure/database/generated"
}

datasource db {
  provider = "postgresql"
}

model Student {
  internalId   Int      @id @default(autoincrement())
  externalId   String   @unique
  enrollmentId String   @unique
  name         String
  email        String   @unique
  phoneNumber  String
  dtBirth      DateTime
  diagnosis    String?
  potential    String?
  difficulties String?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  removed   Boolean  @default(false)

  courseId    String
  course      Course       @relation(fields: [courseId], references: [id])
  attendances Attendance[]
}

model Course {
  id   String @id
  name String

  students Student[]
}

model Attendance {
  internalId          Int      @id @default(autoincrement())
  externalId          String   @unique @default(uuid())
  date                DateTime
  type                String
  demand              String
  generalObservations String

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
  removed   Boolean  @default(false)

  studentId String
  student   Student @relation(fields: [studentId], references: [externalId])
}
