generator client {
  provider = "prisma-client"
  output   = "./src/infrastructure/database/generated"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PROFESSOR
  PEDAGOGUE
  STUDENT
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
  ENABLED
  DISABLED
}

enum ScheduleSlotStatus {
  CREATED
  PENDING
  BOOKED
}

enum ScheduleStatus {
  PENDING
  CONFIRMED
  CANCELED_BY_STUDENT
  CANCELED_BY_PEDAGOGUE
  EXPIRED
  COMPLETED
  MISSED
}

enum DaysOfWeek {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

model Student {
  internalId   Int      @id @default(autoincrement())
  externalId   String   @unique
  enrollmentId String   @unique
  name         String
  email        String   @unique
  phoneNumber  String
  dtBirth      DateTime
  term         String?
  potential    String?
  difficulties String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  removed      Boolean  @default(false)

  courseId Int
  course   Course @relation(fields: [courseId], references: [internalId])

  attendances Attendance[]
  reports     Report[]
  diagnoses   StudentDiagnosis[]
  enrollments Enrollment[]
  schedules   Schedule[]
}

model AccountRequest {
  internalId   Int        @id @default(autoincrement())
  externalId   String     @unique
  registration String     @unique
  name         String
  email        String     @unique
  phoneNumber  String?
  password     String
  role         Role?
  userStatus   UserStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  removed   Boolean  @default(false)
}

model Pedagogue {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  registration String  @unique
  name         String
  email        String  @unique
  phoneNumber  String?
  password     String

  userStatus UserStatus @default(APPROVED)

  maxAttendanceTime Int? @default(60)

  removed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  passwordResets PasswordReset[]
  attendances    Attendance[]
  reports        Report[]
  schedules      Schedule[]
  scheduleSlots  ScheduleSlot[]
}

model Professor {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  registration String  @unique
  name         String
  email        String  @unique
  phoneNumber  String?
  password     String

  userStatus UserStatus @default(APPROVED)

  removed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks          Feedback[]
  classProfessors    ClassProfessor[]
  coordinatedCourses Course[]         @relation("Coordinator")
  passwordResets     PasswordReset[]
}

model Attendance {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  studentId   Int
  pedagogueId Int?
  typeId      Int

  createdAt  DateTime @default(now())
  attendedAt DateTime
  updatedAt  DateTime @updatedAt

  demand      String?
  observation String?
  removed     Boolean @default(false)

  student   Student        @relation(fields: [studentId], references: [internalId])
  pedagogue Pedagogue?     @relation(fields: [pedagogueId], references: [internalId])
  type      AttendanceType @relation(fields: [typeId], references: [internalId])
  schedules Schedule[]
}

model AttendanceType {
  internalId Int    @id @default(autoincrement())
  externalid String @unique

  name String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  removed   Boolean  @default(false)

  attendances Attendance[]
}

model Subject {
  internalId Int      @id @default(autoincrement())
  externalId String   @unique
  name       String
  code       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  classOfferings ClassOffering[]
}

model Course {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  name      String
  acronym   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  removed   Boolean  @default(false)

  coordinatorId Int?
  coordinator   Professor? @relation("Coordinator", fields: [coordinatorId], references: [internalId])

  students       Student[]
  classOfferings ClassOffering[]
}

model Semester {
  internalId Int      @id @default(autoincrement())
  externalId String   @unique
  code       String   @unique
  startDate  DateTime
  endDate    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  classOfferings ClassOffering[]
}

model Report {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  studentId   Int
  pedagogueId Int

  condition      String?
  recommendation String?
  conclusion     String?
  status         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student   Student   @relation(fields: [studentId], references: [internalId])
  pedagogue Pedagogue @relation(fields: [pedagogueId], references: [internalId])

  feedbacks Feedback[]
}

model Feedback {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  reportId    Int
  professorId Int

  title    String?
  bodytext String?
  status   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  report    Report    @relation(fields: [reportId], references: [internalId])
  professor Professor @relation(fields: [professorId], references: [internalId])
}

model Diagnosis {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  name    String
  acronym String?
  CID     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  removed   Boolean  @default(false)

  students StudentDiagnosis[]
}

model StudentDiagnosis {
  studentId   Int
  diagnosisId Int

  student   Student   @relation(fields: [studentId], references: [internalId])
  diagnosis Diagnosis @relation(fields: [diagnosisId], references: [internalId])

  @@id([studentId, diagnosisId])
}

model ClassOffering {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  courseId   Int
  semesterId Int
  subjectId  Int

  daysWeek String?
  hour     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course   Course   @relation(fields: [courseId], references: [internalId])
  semester Semester @relation(fields: [semesterId], references: [internalId])
  subject  Subject  @relation(fields: [subjectId], references: [internalId])

  enrollments     Enrollment[]
  classProfessors ClassProfessor[]
}

model Enrollment {
  studentId Int
  classId   Int

  student Student       @relation(fields: [studentId], references: [internalId])
  class   ClassOffering @relation(fields: [classId], references: [internalId])

  @@id([studentId, classId])
}

model ClassProfessor {
  professorId Int
  classId     Int

  professor Professor     @relation(fields: [professorId], references: [internalId])
  class     ClassOffering @relation(fields: [classId], references: [internalId])

  @@id([professorId, classId])
}

model PasswordReset {
  internalId Int       @id @default(autoincrement())
  token      String    @unique
  expiresAt  DateTime
  createdAt  DateTime  @default(now())
  usedAt     DateTime?

  professorId Int?
  professor   Professor? @relation(fields: [professorId], references: [internalId])

  pedagogueId Int?
  pedagogue   Pedagogue? @relation(fields: [pedagogueId], references: [internalId])
}

model Schedule {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  pedagogueId Int
  pedagogue   Pedagogue @relation(fields: [pedagogueId], references: [internalId])

  studentId Int?
  student   Student? @relation(fields: [studentId], references: [internalId])

  guestName  String?
  guestEmail String?

  startDate DateTime
  endDate   DateTime

  status ScheduleStatus @default(PENDING)
  token  String         @unique
  reason String?

  attendanceId Int?
  attendance   Attendance? @relation(fields: [attendanceId], references: [internalId])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  removed   Boolean  @default(false)

  slots ScheduleSlot[]
}

model ScheduleSlot {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  pedagogueId Int
  pedagogue   Pedagogue @relation(fields: [pedagogueId], references: [internalId])

  scheduleId Int?
  schedule   Schedule? @relation(fields: [scheduleId], references: [internalId])

  startDateTime  DateTime
  endDateTime    DateTime
  attendanceTime Int

  status ScheduleSlotStatus @default(CREATED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  removed   Boolean  @default(false)
}
