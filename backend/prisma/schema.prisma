generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Student {
  internalId Int    @id @default(autoincrement())
  externalId String @unique

  enrollmentId String @unique
  name         String
  email        String @unique
  phoneNumber  String
  dtBirth      DateTime

  diagnosis    String?
  potential    String?
  difficulties String?

  courseId String
  course   Course @relation(fields: [courseId], references: [id])
}

model Course {
  id   String @id
  name String

  students Student[]
}
