FROM node:22-alpine

RUN apk add --no-cache openssl
WORKDIR /app

# Copy dependencies and install
COPY package*.json ./
COPY ./prisma ./prisma
RUN npm install

# Copy the code and generate the Prisma Client
COPY . .
RUN npx prisma generate

# Define the variable to development environment
ENV NODE_ENV=test

# Run the development script with hot-reloading
CMD ["npm", "run", "test"]